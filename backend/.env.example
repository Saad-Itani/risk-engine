# Risk Engine - Backend Environment Variables (TEMPLATE)
# Copy this file to backend/.env and fill in real values.
# backend/.env is gitignored and must NEVER be committed.

# ============================================================================
# LLM Recommendations (OpenAI) - required for the AI-Powered Analysis feature
# ============================================================================

# Your OpenAI API key. Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Model used for portfolio recommendations
OPENAI_MODEL=gpt-5.4-mini

# Optional: custom OpenAI-compatible endpoint (leave unset for the default API)
# OPENAI_BASE_URL=

# ============================================================================
# Optional overrides (sensible defaults exist in app/config.py)
# ============================================================================
# DATABASE_URL=sqlite:///risk_engine.db
# DEFAULT_BACKTEST_LOOKBACK=252
# DEFAULT_BACKTEST_STEP=5
# KUPIEC_PVALUE_THRESHOLD=0.05
# LLM_MAX_TOKENS=1000
# LLM_TEMPERATURE=0.3
